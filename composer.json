{
    "name": "seventhings/customer-api-php",
    "description": "PHP SDK for the seventhings API",
    "type": "library",
    "version": "0.1.0",
    "license": "MIT",
    "require": {
        "php": "^8.5",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11"
    },
    "autoload": {
        "psr-4": {
            "Seventhings\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Seventhings\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "test:integration": "vendor/bin/phpunit --testsuite Integration"
    }
}
